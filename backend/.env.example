# ==========================================
# Backend Environment Variables
# Copy this file to .env and fill in your values
# ==========================================

# Server
PORT=4000

# MongoDB
# Local: mongodb://127.0.0.1:27017/Abay_Grand_Hotel
# Docker: Overridden by docker-compose.yml
MONGODB_URI=mongodb://127.0.0.1:27017/Abay_Grand_Hotel
MONGODB_DB_NAME=Abay_Grand_Hotel

# Atlas MongoDB (used by sync feature)
ATLAS_MONGODB_URI=

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# Cloudinary
CLOUDINARY_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_SECRET_KEY=your_api_secret

# Chapa Payment Gateway
# Test keys — replace with live keys in production
CHAPA_SECRET_KEY=CHASECK_TEST-ttCMGESjty3tmzBRPRUYk9gu5O8Xf8sm
CHAPA_PUBLIC_KEY=CHAPUBK_TEST-DQFH3iHjMZeA5LFDP2OOcZNf7LrRYHVq
CHAPA_WEBHOOK_SECRET=CHASECK_TEST-ttCMGESjty3tmzBRPRUYk9gu5O8Xf8sm
CHAPA_ENCRYPTION_KEY=0Or6a5iiGSwKM8TVGejDOBNp
CHAPA_CALLBACK_URL=http://localhost:4000/api/payment/chapa-webhook
CHAPA_RETURN_URL=http://localhost:4000/api/payment/chapa-return

# App URLs (used by backend for CORS and callbacks)
FRONTEND_URL=http://localhost:80
ADMIN_URL=http://localhost:81
BACKEND_URL=http://localhost:4000

# Admin defaults
ADMIN_EMAIL=admin@hotel.com
ADMIN_PASSWORD=Admin@123
ADMIN_NAME=Administrator
ADMIN_ROLE=Super Admin
